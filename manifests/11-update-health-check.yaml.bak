apiVersion: networking.gke.io/v1
kind: HealthCheckPolicy
metadata:
  name: svc-health-l4
  namespace: default
spec:
  targetRef:
    group: ""
    kind: Service
    name: triton-svc-l4
  default:
    checkIntervalSec: 5
    timeoutSec: 5
    config:
      type: HTTP
      httpHealthCheck:
        requestPath: /v2/health/ready
        port: 8000
---
apiVersion: networking.gke.io/v1
kind: HealthCheckPolicy
metadata:
  name: svc-health-g4
  namespace: default
spec:
  targetRef:
    group: ""
    kind: Service
    name: triton-svc-g4
  default:
    checkIntervalSec: 5
    timeoutSec: 5
    config:
      type: HTTP
      httpHealthCheck:
        requestPath: /v2/health/ready
        port: 8000
