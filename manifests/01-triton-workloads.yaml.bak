# L4 Triton Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: triton-recml-l4
  labels:
    app: triton-recml
    gpu: l4
spec:
  replicas: 1
  selector:
    matchLabels:
      app: triton-recml
      gpu: l4
  template:
    metadata:
      labels:
        app: triton-recml
        gpu: l4
    spec:
      nodeSelector:
        cloud.google.com/gke-accelerator: nvidia-l4
      tolerations:
      - key: "nvidia.com/gpu"
        operator: "Exists"
        effect: "NoSchedule"
      initContainers:
      - name: generate-model
        image: nvcr.io/nvidia/pytorch:25.05-py3
        command:
        - python3
        - -c
        - |
          import os
          import torch
          import torch.nn as nn
          class HeavyModel(nn.Module):
              def __init__(self):
                  super().__init__()
                  self.layer = nn.Linear(1024, 1024)
              def forward(self, x):
                  # Do some math to make it not instantaneous
                  for _ in range(1000):
                      x = self.layer(x)
                      x = torch.relu(x)
                  return x
          model = HeavyModel()
          dummy_input = torch.randn(1, 1024)
          traced = torch.jit.trace(model, dummy_input)
          os.makedirs("/models/recml-model/1", exist_ok=True)
          traced.save("/models/recml-model/1/model.pt")
          config = """name: "recml-model"
          platform: "pytorch_libtorch"
          max_batch_size: 0
          input [ { name: "INPUT__0", data_type: TYPE_FP32, dims: [ 1, 1024 ] } ]
          output [ { name: "OUTPUT__0", data_type: TYPE_FP32, dims: [ 1, 1024 ] } ]
          instance_group [ { count: 1, kind: KIND_GPU } ]
          """
          with open("/models/recml-model/config.pbtxt", "w") as f:
              f.write(config)
        volumeMounts:
        - name: model-repository
          mountPath: /models
      containers:
      - name: triton
        image: nvcr.io/nvidia/tritonserver:25.05-py3
        command: ["/opt/tritonserver/bin/tritonserver"]
        args: ["--model-repository=/models", "--allow-metrics=true", "--strict-model-config=false"]
        resources:
          requests: { cpu: "100m", memory: "2Gi" }
          limits: { cpu: "3900m", memory: "8Gi", nvidia.com/gpu: 1 }
        ports:
        - containerPort: 8000
          name: http
        - containerPort: 8002
          name: metrics
        volumeMounts:
        - name: model-repository
          mountPath: /models
      volumes:
      - name: model-repository
        emptyDir: {}
---
# G4 Triton Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: triton-recml-g4
  labels:
    app: triton-recml
    gpu: g4
spec:
  replicas: 1
  selector:
    matchLabels:
      app: triton-recml
      gpu: g4
  template:
    metadata:
      labels:
        app: triton-recml
        gpu: g4
    spec:
      nodeSelector:
        cloud.google.com/gke-accelerator: nvidia-rtx-pro-6000
      tolerations:
      - key: "nvidia.com/gpu"
        operator: "Exists"
        effect: "NoSchedule"
      initContainers:
      - name: generate-model
        image: nvcr.io/nvidia/pytorch:25.05-py3
        command:
        - python3
        - -c
        - |
          import os
          import torch
          import torch.nn as nn
          class HeavyModel(nn.Module):
              def __init__(self):
                  super().__init__()
                  self.layer = nn.Linear(1024, 1024)
              def forward(self, x):
                  for _ in range(100):
                      x = self.layer(x)
                      x = torch.relu(x)
                  return x
          model = HeavyModel()
          dummy_input = torch.randn(1, 1024)
          traced = torch.jit.trace(model, dummy_input)
          os.makedirs("/models/recml-model/1", exist_ok=True)
          traced.save("/models/recml-model/1/model.pt")
          config = """name: "recml-model"
          platform: "pytorch_libtorch"
          max_batch_size: 0
          input [ { name: "INPUT__0", data_type: TYPE_FP32, dims: [ 1, 1024 ] } ]
          output [ { name: "OUTPUT__0", data_type: TYPE_FP32, dims: [ 1, 1024 ] } ]
          instance_group [ { count: 1, kind: KIND_GPU } ]
          """
          with open("/models/recml-model/config.pbtxt", "w") as f:
              f.write(config)
        volumeMounts:
        - name: model-repository
          mountPath: /models
      containers:
      - name: triton
        image: nvcr.io/nvidia/tritonserver:25.05-py3
        command: ["/opt/tritonserver/bin/tritonserver"]
        args: ["--model-repository=/models", "--allow-metrics=true", "--strict-model-config=false"]
        resources:
          requests: { cpu: "100m", memory: "2Gi" }
          limits: { cpu: "16", memory: "32Gi", nvidia.com/gpu: 1 }
        ports:
        - containerPort: 8000
          name: http
        - containerPort: 8002
          name: metrics
        volumeMounts:
        - name: model-repository
          mountPath: /models
      volumes:
      - name: model-repository
        emptyDir: {}